# Absolute path on the Ubuntu host to your Pi-hole's etc-pihole folder
# (the one you already mount into the pihole container). This gets mounted
# READ-ONLY into this app's backend container.
PIHOLE_ETC_PATH=/home/steve/pihole/etc-pihole

# Host port to expose the dashboard on
DASHBOARD_PORT=8090

# Optional dashboard login (HTTP Basic auth). Leave DNSWATCH_AUTH_PASSWORD blank
# to keep the dashboard open on your LAN; set it to require a password for the
# whole app (API + UI). Username defaults to "admin".
# DNSWATCH_AUTH_USERNAME=admin
# DNSWATCH_AUTH_PASSWORD=change-me
